<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mon Compte - YAMONFILM</title>
    <style>
        *{ box-sizing:border-box; margin:0; padding:0; font-family:Arial, sans-serif; }
        body{ background:#0f0f0f; color:white; overflow-x: hidden; }

        /* NAV */
        .navbar{
            position:fixed; top:0; left:0; width:100%; height:60px;
            display:flex; justify-content:space-between; align-items:center;
            padding:0 20px; background:rgba(0,0,0,0.9);
            z-index:1000; border-bottom: 1px solid #333;
        }
        .logo{ color:#e50914; font-size:28px; font-weight:bold; text-decoration:none; }

        /* CONTAINER PRINCIPAL */
        .account-container {
            max-width: 800px;
            margin: 100px auto;
            padding: 20px;
        }
        h1 { font-size: 32px; margin-bottom: 30px; border-bottom: 1px solid #333; padding-bottom: 10px;}

        /* SECTIONS */
        .account-section {
            display: flex;
            padding: 20px 0;
            border-bottom: 1px solid #333;
            flex-wrap: wrap;
        }
        .section-left { flex: 1; min-width: 200px; color: #666; font-size: 18px; font-weight: bold; }
        .section-right { flex: 2; min-width: 300px; }

        .info-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        .info-text { font-size: 16px; color: white; }
        .action-link { color: #0073e6; cursor: pointer; text-decoration: none; font-size: 14px; }
        .action-link:hover { text-decoration: underline; }

        /* FORMULAIRES CACHÉS */
        .edit-form { display: none; background: #1c1c1c; padding: 20px; border-radius: 4px; margin-top: 10px; border: 1px solid #444; }
        input { 
            width: 100%; padding: 12px; margin: 10px 0; 
            background: #333; border: 1px solid #444; 
            color: white; border-radius: 4px; 
        }
        .btn-group { display: flex; gap: 10px; margin-top: 10px; }
        .btn-save { background: #e50914; color: white; border: none; padding: 10px 20px; cursor: pointer; border-radius: 4px; font-weight: bold; }
        .btn-cancel { background: #666; color: white; border: none; padding: 10px 20px; cursor: pointer; border-radius: 4px; }

        #msg { text-align: center; padding: 10px; margin-top: 20px; border-radius: 4px; display: none; }
    </style>
</head>
<body>

<div class="navbar">
    <a href="index.html" class="logo">YAMONFILM</a>
</div>

<div class="account-container">
    <h1>Compte</h1>

    <div class="account-section">
        <div class="section-left">MEMBRE DEPUIS</div>
        <div class="section-right">
            <div class="info-row">
                <span id="user-email" class="info-text">Chargement...</span>
                <span class="action-link" onclick="toggleEdit('email-form')">Modifier l'adresse e-mail</span>
            </div>
            
            <div id="email-form" class="edit-form">
                <input type="email" id="new-email" placeholder="Nouvelle adresse e-mail">
                <div class="btn-group">
                    <button class="btn-save" onclick="updateEmailAddr()">Enregistrer</button>
                    <button class="btn-cancel" onclick="toggleEdit('email-form')">Annuler</button>
                </div>
            </div>
        </div>
    </div>

    <div class="account-section">
        <div class="section-left">MOT DE PASSE</div>
        <div class="section-right">
            <div class="info-row">
                <span class="info-text">********</span>
                <span class="action-link" onclick="toggleEdit('pass-form')">Modifier le mot de passe</span>
            </div>

            <div id="pass-form" class="edit-form">
                <input type="password" id="new-pass" placeholder="Nouveau mot de passe">
                <div class="btn-group">
                    <button class="btn-save" onclick="updatePass()">Enregistrer</button>
                    <button class="btn-cancel" onclick="toggleEdit('pass-form')">Annuler</button>
                </div>
            </div>
        </div>
    </div>

    <div class="account-section">
        <div class="section-left">FORMULE</div>
        <div class="section-right">
            <div class="info-row">
                <span class="info-text" style="font-weight: bold;">YAMONFILM PREMIUM</span>
                <span style="color: #e50914; font-size: 12px; border: 1px solid #e50914; padding: 2px 5px; border-radius: 3px;">ACTIF</span>
            </div>
        </div>
    </div>

    <div id="msg"></div>
</div>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
    import { getAuth, onAuthStateChanged, updateEmail, updatePassword } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

    const firebaseConfig = { apiKey: "AIzaSyAQnexePSWAJdgZc2WO2BFKL8Z_jnDKbqE", authDomain: "yamonfilm-fead8.firebaseapp.com", projectId: "yamonfilm-fead8" };
    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);

    const msgDiv = document.getElementById("msg");

    onAuthStateChanged(auth, (user) => {
        if (user) {
            document.getElementById("user-email").innerText = user.email;
        } else {
            window.location.href = "login.html";
        }
    });

    window.toggleEdit = (id) => {
        const form = document.getElementById(id);
        form.style.display = (form.style.display === "block") ? "none" : "block";
    };

    function showMsg(text, color) {
        msgDiv.innerText = text;
        msgDiv.style.background = color;
        msgDiv.style.display = "block";
        setTimeout(() => msgDiv.style.display = "none", 3000);
    }

    // MISE À JOUR EMAIL
    window.updateEmailAddr = async () => {
        const newEmail = document.getElementById("new-email").value;
        if (!newEmail) return;
        try {
            await updateEmail(auth.currentUser, newEmail);
            showMsg("Email mis à jour avec succès !", "green");
            document.getElementById("user-email").innerText = newEmail;
            toggleEdit('email-form');
        } catch (error) {
            showMsg("Erreur : Veuillez vous reconnecter avant de modifier l'email.", "red");
        }
    };

    // MISE À JOUR MOT DE PASSE
    window.updatePass = async () => {
        const newPass = document.getElementById("new-pass").value;
        if (newPass.length < 6) { showMsg("6 caractères minimum.", "orange"); return; }
        try {
            await updatePassword(auth.currentUser, newPass);
            showMsg("Mot de passe mis à jour !", "green");
            toggleEdit('pass-form');
        } catch (error) {
            showMsg("Erreur : Veuillez vous reconnecter pour cette action.", "red");
        }
    };
</script>
</body>
</html>
